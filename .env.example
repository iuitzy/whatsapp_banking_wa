# Groq API
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# Database
DATABASE_URL=postgresql://banking_user:banking_pass@localhost:5432/banking_db

# Redis
REDIS_URL=redis://localhost:6379

# OpenWA WhatsApp Gateway
OPENWA_URL=http://localhost:2785
OPENWA_API_KEY=your_openwa_api_key_here
OPENWA_SESSION_ID=hsbc-assistant

# Security — webhook authentication
WEBHOOK_SECRET=your_random_webhook_secret_here